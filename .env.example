# Copy to .env and fill in values. Never commit .env to GitHub.

# Database — Railway injects this automatically when Postgres plugin is added
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth — generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here
